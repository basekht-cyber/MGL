# SMTP credentials for the contact form (Nodemailer)
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@metagrowthlabs.com
SMTP_PASS=your-app-password-here

# Where contact form submissions are delivered
CONTACT_TO=info@metagrowthlabs.com

# Public site URL (used for SEO metadata / sitemap)
NEXT_PUBLIC_SITE_URL=https://www.metagrowthlabs.com

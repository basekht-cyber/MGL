# Meta Growth Labs — Apache / LiteSpeed config for Hostinger shared hosting.

# ---- Canonical host: https://metagrowthlabs.com ---------------------------
# Serving the same page on both www and non-www splits ranking signals between
# two URLs. One host must 301 to the other; this picks the bare domain, which
# is what the <link rel="canonical"> tag and sitemap.xml also point at.
<IfModule mod_rewrite.c>
  RewriteEngine On

  # www -> non-www, forcing https in the same hop so there is no redirect chain
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # http -> https for the bare domain
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# Serve the exported 404 page instead of Apache's default
ErrorDocument 404 /404.html

# ---- Compression ----------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ---- Caching --------------------------------------------------------------
# These MUST live in mod_headers. Hostinger does not load mod_expires, so
# anything nested in <IfModule mod_expires.c> is skipped silently — which left
# every asset on the server default of "no-store, must-revalidate" and made
# browsers re-download the whole ~1 MB bundle on every single visit.
<IfModule mod_headers.c>
  # Images and fonts served from public/ are not content-hashed, so keep the
  # window short enough that replacing one actually propagates.
  SetEnvIf Request_URI "\.(svg|png|jpe?g|webp|gif|ico|woff2?)$" MGL_CACHE_MED
  Header always set Cache-Control "public, max-age=604800" env=MGL_CACHE_MED

  # Everything under /_next/static/ has a content hash in its filename, so a
  # rebuild produces a new URL and these can never go stale. Declared after the
  # rule above so it wins for hashed fonts.
  SetEnvIf Request_URI "^/_next/static/" MGL_CACHE_LONG
  Header always set Cache-Control "public, max-age=31536000, immutable" env=MGL_CACHE_LONG

  # HTML revalidates on every visit, otherwise a redeploy never reaches anyone.
  SetEnvIf Request_URI "\.html$" MGL_CACHE_HTML
  SetEnvIf Request_URI "/$" MGL_CACHE_HTML
  Header always set Cache-Control "public, max-age=0, must-revalidate" env=MGL_CACHE_HTML
</IfModule>

# ---- Security headers -----------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ---- Misc -----------------------------------------------------------------
Options -Indexes
AddType image/svg+xml .svg

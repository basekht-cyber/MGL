# Meta Growth Labs — Apache / LiteSpeed config for Hostinger shared hosting.

# ---- Canonical host: https://metagrowthlabs.com ---------------------------
# Serving the same page on both www and non-www splits ranking signals between
# two URLs. One host must 301 to the other; this picks the bare domain, which
# is what the <link rel="canonical"> tag and sitemap.xml also point at.
<IfModule mod_rewrite.c>
  RewriteEngine On

  # www -> non-www, forcing https in the same hop so there is no redirect chain
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # http -> https for the bare domain
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# Serve the exported 404 page instead of Apache's default
ErrorDocument 404 /404.html

# ---- Compression ----------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ---- Caching --------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # Next.js fingerprints these filenames, so they can be cached forever.
  <FilesMatch "\.(js|css|woff2)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, immutable"
  </FilesMatch>

  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"

  # HTML must revalidate or visitors get stale pages after a redeploy.
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ---- Security headers -----------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ---- Misc -----------------------------------------------------------------
Options -Indexes
AddType image/svg+xml .svg
